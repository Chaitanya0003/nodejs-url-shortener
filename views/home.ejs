<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Home Page</title>
  </head>
  <body>
    <h1>URL Shortener</h1>
    <% if (locals.shortId) { %>
     <p>URL generated: <a href="http://localhost:8001/url/<%= locals.shortId %>" target="_blank">http://localhost:8001/url/<%= locals.shortId %></a></p>
    <% } %>
    <form action="/url" method="POST">
      <label htmlFor="url">Enter your original URL:</label>
      <input
        type="text"
        name="url"
        id="url"
        placeholder="https://example.com"
      />
      <button type="submit">Shorten</button>
    </form>
    <table width="100%" border="1" style="margin-top: 20px">
        <thead text-align="center">
            <tr>
                <th>Sr. No.</th>
                <th>Short ID</th>
                <th>Redirect URL</th>
                <th>Total Clicks</th>
            </tr>
        </thead>
        <tbody style="text-align: center">
            <% if (locals.urls) { %>
                <% locals.urls.forEach((url, index) => { %>
                 <tr>
                    <td><%= index + 1 %></td>
                    <td><%= url.shortId %></td>
                    <td><%= url.redirectUrl %></td>
                    <td><%= url.visitHistory.length %></td>
                </tr>
                <% }) %>
            <% } %>
        </tbody>
    </table>
  </body>
</html>
